    <worksheet name='view1'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#00bfb3' fontname='Tableau Semibold'>Age Wise Staus</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Comprehensive_Banking_Database' name='federated.0cfw1qb157nd83145kff814vckit' />
          </datasources>
          <datasource-dependencies datasource='federated.0cfw1qb157nd83145kff814vckit'>
            <column datatype='real' name='[Account Balance]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Age]' role='measure' type='quantitative' />
            <column caption='Age Group' datatype='string' name='[Calculation_2415618265455816704]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Age] &gt;= 18 AND [Age] &lt;= 30 THEN &quot;Young (18-30)&quot;&#13;&#10;ELSEIF [Age] &gt;= 31 AND [Age] &lt;= 45 THEN &quot;Mid Age (31-45)&quot;&#13;&#10;ELSEIF [Age] &gt;= 46 AND [Age] &lt;= 60 THEN &quot;Senior Working (46-60)&quot;&#13;&#10;ELSE &quot;Retired 60+&quot;&#13;&#10;END' />
            </column>
            <column caption='Card Utilization %' datatype='real' name='[Calculation_2415618265461030913]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Credit Card Balance]) / SUM([Credit Limit])' />
            </column>
            <column caption='Customer Name' datatype='string' name='[Calculation_2415618265735270409]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[First Name] + &quot; &quot; + [Last Name]' />
            </column>
            <column datatype='real' name='[Credit Card Balance]' role='measure' type='quantitative' />
            <column datatype='real' name='[Credit Limit]' role='measure' type='quantitative' />
            <column datatype='string' name='[First Name]' role='dimension' type='nominal' />
            <column datatype='real' name='[Interest Rate]' role='measure' type='quantitative' />
            <column datatype='string' name='[Last Name]' role='dimension' type='nominal' />
            <column datatype='real' name='[Loan Amount]' role='measure' type='quantitative' />
            <column datatype='real' name='[Minimum Payment Due]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Rewards Points]' role='measure' type='quantitative' />
            <column datatype='real' name='[Transaction Amount]' role='measure' type='quantitative' />
            <column caption='Transaction ID' datatype='integer' name='[TransactionID]' role='dimension' type='ordinal' />
            <column-instance column='[Account Balance]' derivation='Avg' name='[avg:Account Balance:qk]' pivot='key' type='quantitative' />
            <column-instance column='[TransactionID]' derivation='Count' name='[cnt:TransactionID:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2415618265455816704]' derivation='None' name='[none:Calculation_2415618265455816704:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_2415618265735270409]' derivation='None' name='[none:Calculation_2415618265735270409:nk]' pivot='key' type='nominal' />
            <column-instance column='[Credit Limit]' derivation='Sum' name='[sum:Credit Limit:qk]' pivot='key' type='quantitative' />
