      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0cfw1qb157nd83145kff814vckit].[cnt:TransactionID:qk]&quot;' value='Transaction ID Count' />
        </aliases>
      </column>
      <column datatype='string' name='[Account Type]' role='dimension' type='nominal' />
      <column datatype='integer' name='[Branch ID]' role='dimension' type='ordinal' />
      <column caption='Age Group' datatype='string' name='[Calculation_2415618265455816704]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &gt;= 18 AND [Age] &lt;= 30 THEN &quot;Young (18-30)&quot;&#13;&#10;ELSEIF [Age] &gt;= 31 AND [Age] &lt;= 45 THEN &quot;Mid Age (31-45)&quot;&#13;&#10;ELSEIF [Age] &gt;= 46 AND [Age] &lt;= 60 THEN &quot;Senior Working (46-60)&quot;&#13;&#10;ELSE &quot;Retired 60+&quot;&#13;&#10;END' />
      </column>
      <column caption='Card Utilization %' datatype='real' name='[Calculation_2415618265461030913]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Credit Card Balance]) / SUM([Credit Limit])' />
      </column>
      <column caption='MoM % Change' datatype='real' name='[Calculation_2415618265479696387]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Credit Card Balance]) &#13;&#10; - LOOKUP(SUM([Credit Card Balance]), -1))&#13;&#10;/&#13;&#10;ABS(LOOKUP(SUM([Credit Card Balance]), -1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Feedback Resolution %' datatype='real' name='[Calculation_2415618265480843268]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [Resolution Status] = &quot;Resolved&quot; THEN 1 END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([Feedback ID])' />
      </column>
      <column caption='Total Feedback Count' datatype='integer' name='[Calculation_2415618265480933381]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Feedback ID])' />
      </column>
      <column caption='Loan Approval Rate' datatype='real' name='[Calculation_2415618265482416134]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [Loan Status] = &quot;Approved&quot; OR [Loan Status] = &quot;Closed&quot; &#13;&#10;    THEN 1 END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([Loan ID])' />
      </column>
      <column caption='Total Balance (Millions)' datatype='real' name='[Calculation_2415618265484537864]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Account Balance]/ 1000000' />
      </column>
      <column caption='Customer Name' datatype='string' name='[Calculation_2415618265735270409]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[First Name] + &quot; &quot; + [Last Name]' />
      </column>
